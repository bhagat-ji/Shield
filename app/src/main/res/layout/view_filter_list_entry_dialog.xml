<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_height="wrap_content"
    android:layout_width="match_parent" >

    <LinearLayout
        android:orientation="vertical"
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp" >

        <!-- Filter List. -->
        <TextView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:text="@string/filterlist"
            android:textSize="12sp"
            android:textColor="@color/blue_text"
            android:layout_marginTop="5dp" />

        <TextView
            android:id="@+id/filter_list_textview"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:textSize="16sp"
            android:textColor="?android:textColorPrimary"
            android:textIsSelectable="true" />

        <!-- Sublist. -->
        <TextView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:text="@string/sublist"
            android:textSize="12sp"
            android:textColor="@color/blue_text"
            android:layout_marginTop="5dp" />

        <TextView
            android:id="@+id/sublist_textview"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:textSize="16sp"
            android:textColor="?android:textColorPrimary"
            android:textIsSelectable="true" />

        <!-- Applied Entry List. -->
        <TextView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:text="@string/applied_entry_list"
            android:textSize="12sp"
            android:textColor="@color/blue_text"
            android:layout_marginTop="5dp" />

        <TextView
            android:id="@+id/applied_entry_list_textview"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:textSize="16sp"
            android:textColor="?android:textColorPrimary"
            android:textIsSelectable="true" />

        <!-- Domain. -->
        <TextView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:text="@string/domain"
            android:textSize="12sp"
            android:textColor="@color/blue_text"
            android:layout_marginTop="5dp" />

        <TextView
            android:id="@+id/domain_textview"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:textSize="16sp"
            android:textColor="?android:textColorPrimary"
            android:textIsSelectable="true" />

        <!-- Domain List. -->
        <TextView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:text="@string/domain_list"
            android:textSize="12sp"
            android:textColor="@color/blue_text"
            android:layout_marginTop="5dp" />

        <TextView
            android:id="@+id/domain_list_textview"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:textSize="16sp"
            android:textColor="?android:textColorPrimary"
            android:textIsSelectable="true" />

        <!-- Third Party. -->
        <TextView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:text="@string/third_party"
            android:textSize="12sp"
            android:textColor="@color/blue_text"
            android:layout_marginTop="5dp" />

        <TextView
            android:id="@+id/third_party_textview"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:textSize="16sp"
            android:textColor="?android:textColorPrimary"
            android:textIsSelectable="true" />

        <!-- Initial Match. -->
        <TextView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:text="@string/initial_match"
            android:textSize="12sp"
            android:textColor="@color/blue_text"
            android:layout_marginTop="5dp" />

        <TextView
            android:id="@+id/initial_match_textview"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:textSize="16sp"
            android:textColor="?android:textColorPrimary"
            android:textIsSelectable="true" />

        <!-- Final Match. -->
        <TextView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:text="@string/final_match"
            android:textSize="12sp"
            android:textColor="@color/blue_text"
            android:layout_marginTop="5dp" />

        <TextView
            android:id="@+id/final_match_textview"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:textSize="16sp"
            android:textColor="?android:textColorPrimary"
            android:textIsSelectable="true" />

        <!-- Applied Filter Options. -->
        <TextView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:text="@string/applied_filter_options"
            android:textSize="12sp"
            android:textColor="@color/blue_text"
            android:layout_marginTop="5dp" />

        <TextView
            android:id="@+id/applied_filter_options_textview"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:textSize="16sp"
            android:textColor="?android:textColorPrimary"
            android:textIsSelectable="true" />

        <!-- Original Filter Options. -->
        <TextView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:text="@string/original_filter_options"
            android:textSize="12sp"
            android:textColor="@color/blue_text"
            android:layout_marginTop="5dp" />

        <TextView
            android:id="@+id/original_filter_options_textview"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:textSize="16sp"
            android:textColor="?android:textColorPrimary"
            android:textIsSelectable="true" />

        <!-- Original Entry. -->
        <TextView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:text="@string/original_entry"
            android:textSize="12sp"
            android:textColor="@color/blue_text"
            android:layout_marginTop="5dp" />

        <TextView
            android:id="@+id/original_entry_textview"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:textSize="16sp"
            android:textColor="?android:textColorPrimary"
            android:textIsSelectable="true" />
    </LinearLayout>
</ScrollView>